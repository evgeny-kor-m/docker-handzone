{
  "appenders": {
    "console": { "type": "console","layout": { "type": "pattern", "pattern": "[%p] %d{ISO8601_WITH_TZ_OFFSET} - %m" } },
    "file": {
      "type": "file",
      "filename": "logs/myapp.log",
      "maxLogSize": 10485760, 
      "backups": 3,
      "compress": true,
      "layout": {
        "type": "pattern",
        "pattern": "[%p] %d{ISO8601_WITH_TZ_OFFSET} - %m"
      }
    }
  },
  "categories": {
    "default": { "appenders": ["console", "file"], "level": "info" }
  }
}
